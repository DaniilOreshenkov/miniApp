# ─── ЮКасса ──────────────────────────────────────────────────────────────────
# Профиль → Настройки → API-ключи на https://yookassa.ru/my/merchant/integration/api-keys
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Берётся из https://console.upstash.com → Database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Безопасность ────────────────────────────────────────────────────────────
# Случайная строка ~32 символа: openssl rand -hex 16
CRON_SECRET=
CLIENT_API_SECRET=

# ─── Приложение ──────────────────────────────────────────────────────────────
# URL задеплоенного приложения (без trailing slash). Нужен для cron→charge вызовов.
APP_URL=https://your-app.vercel.app

# ─── Фискализация 54-ФЗ (необязательно) ─────────────────────────────────────
# Включать только если в ЛК ЮКасса подключена онлайн-касса
YOOKASSA_FISCALIZATION=false
YOOKASSA_RECEIPT_EMAIL=
YOOKASSA_VAT_CODE=1

# ─── Фронтенд ─────────────────────────────────────────────────────────────────
# Для кнопки "Отмена" в PaywallScreen — должна совпадать с CLIENT_API_SECRET
VITE_CLIENT_API_SECRET=
