# Production environment variables
# Используется при сборке: vite build
# ВАЖНО: не коммить этот файл в git (добавь .env.production в .gitignore)

# Секрет для авторизации клиентских запросов к /api/cancel-subscription
# Должен совпадать с CLIENT_API_SECRET на сервере (Vercel env)
VITE_CLIENT_API_SECRET=замени_на_реальный_секрет
